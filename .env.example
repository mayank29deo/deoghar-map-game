# All optional — the game runs fully without any of these.

# Global leaderboard: free Supabase project, run supabase/schema.sql in its
# SQL editor, then copy from Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Real satellite ground under the 3D city: free key from cloud.maptiler.com
# (Account → API keys). Restrict allowed origins to your domains.
VITE_MAPTILER_KEY=

# Real Street View photo card on every delivery: Google Cloud Console →
# enable "Maps Embed API" (it is $0 / unlimited) → create an API key →
# restrict it to HTTP referrers (localhost + your vercel domain).
VITE_GMAPS_EMBED_KEY=
